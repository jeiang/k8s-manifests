#!/bin/sh
set -eu

message_file="$1"
subject="$(sed -n '1p' "$message_file")"

case "$subject" in
  ""|Merge\ *|Revert\ \"*|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

if printf '%s\n' "$subject" | grep -Eq '^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9._/-]+\))?(!)?: .+'; then
  exit 0
fi

cat >&2 <<'EOF'
Commit message must use conventional commits format:

  <type>[optional scope][optional !]: <description>

Allowed types: build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test
Example: feat(netbird): add reverse proxy
EOF

exit 1
